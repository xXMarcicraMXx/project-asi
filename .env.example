# ── INFRASTRUCTURE ───────────────────────────────────────────────────────────
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ── SHARED SECRETS (used by both ASI and ORACLE) ──────────────────────────────
# Set once — both projects read the same values
ANTHROPIC_API_KEY=sk-ant-...
PINECONE_API_KEY=...
SLACK_BOT_TOKEN=xoxb-...          # Same Slack app, different channels per project

# ── PROJECT ASI ───────────────────────────────────────────────────────────────
ASI_PINECONE_INDEX_NAME=asi-personas
ASI_SLACK_CHANNEL_ID=C...         # ASI approval channel (never post to ORACLE's)
RSS_FEED_URLS=https://feeds.bbci.co.uk/news/rss.xml,https://feeds.bbci.co.uk/news/business/rss.xml,https://www.theguardian.com/world/rss,https://feeds.npr.org/1017/rss.xml,https://rss.nytimes.com/services/xml/rss/nyt/World.xml
ASI_MAX_USD_PER_JOB=2.00
ASI_OUTPUT_DIR=/data/asi-output

# ── PROJECT ORACLE ────────────────────────────────────────────────────────────
# ORACLE_ prefixed vars are owned by the ORACLE session — ASI never modifies these
OPENAI_API_KEY=sk-...
ORACLE_PINECONE_INDEX_NAME=oracle-personas
ORACLE_SLACK_CHANNEL_ID=C...      # ORACLE approval channel (never post from ASI)
ORACLE_OUTPUT_DIR=/data/oracle-output
